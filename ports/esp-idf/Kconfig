# ESP-IDF Kconfig for NoxTLS

menuconfig NOXTLS
	bool "NoxTLS cryptography and TLS library"
	default n
	help
	  Enable the NoxTLS library from Argenox. Add this component via
	  EXTRA_COMPONENT_DIRS pointing at ports/esp-idf (see ports/esp-idf/README.md).

if NOXTLS

choice NOXTLS_PROFILE
	prompt "Feature profile"
	default NOXTLS_PROFILE_DEFAULT
	help
	  Predefined feature sets matching noxtls/CMakeLists.txt profiles.
	  For full control over every NOXTLS_FEATURE_* option in menuconfig,
	  select profile "default". Other profiles override many options at
	  build time regardless of individual Kconfig toggles.

config NOXTLS_PROFILE_DEFAULT
	bool "default"

config NOXTLS_PROFILE_MINIMAL_TLS_CLIENT
	bool "minimal_tls_client"

config NOXTLS_PROFILE_TLS_SERVER_PKI
	bool "tls_server_pki"

config NOXTLS_PROFILE_CRYPTO_ONLY
	bool "crypto_only"

config NOXTLS_PROFILE_FIPS_LIKE
	bool "fips_like_profile"

endchoice

config NOXTLS_PROFILE
	string
	default "minimal_tls_client" if NOXTLS_PROFILE_MINIMAL_TLS_CLIENT
	default "tls_server_pki" if NOXTLS_PROFILE_TLS_SERVER_PKI
	default "crypto_only" if NOXTLS_PROFILE_CRYPTO_ONLY
	default "fips_like_profile" if NOXTLS_PROFILE_FIPS_LIKE
	default "default"

choice NOXTLS_SIDECHANNEL
	prompt "Side-channel profile"
	default NOXTLS_SIDECHANNEL_BALANCED
	help
	  Maps to NOXTLS_SIDECHANNEL_PROFILE_* and NOXTLS_CT_COMPARE in
	  noxtls_config.h (CT compare is off only for "performance").

config NOXTLS_SIDECHANNEL_PERFORMANCE
	bool "performance"

config NOXTLS_SIDECHANNEL_BALANCED
	bool "balanced"

config NOXTLS_SIDECHANNEL_CONSTANT_TIME_STRICT
	bool "constant_time_strict"

endchoice

config NOXTLS_SIDECHANNEL
	string
	default "performance" if NOXTLS_SIDECHANNEL_PERFORMANCE
	default "constant_time_strict" if NOXTLS_SIDECHANNEL_CONSTANT_TIME_STRICT
	default "balanced"

config NOXTLS_USE_ESP_ENTROPY
	bool "Seed DRBG from ESP hardware RNG (esp_fill_random)"
	default y
	depends on NOXTLS_FEATURE_DRBG
	help
	  Registers esp_fill_random() with noxtls_drbg_set_entropy_callback()
	  during component init (constructor or noxtls_esp_idf_init()).

menu "ESP Hardware Crypto Acceleration"

config NOXTLS_ESP_HW_ECC
	bool "Use ESP hardware ECC point multiplication (P-256 when supported)"
	default y
	depends on NOXTLS_FEATURE_ECC && SOC_ECC_SUPPORTED
	help
	  Enables ECC scalar multiplication offload through ESP-IDF HAL when the
	  selected target provides ECC hardware (SOC_ECC_SUPPORTED). Targets
	  without ECC hardware automatically fall back to software.

config NOXTLS_ESP_HW_ECDSA
	bool "Use ESP hardware ECC path for ECDSA P-256 operations"
	default y
	depends on NOXTLS_FEATURE_ECDSA && NOXTLS_FEATURE_ECC && SOC_ECC_SUPPORTED
	help
	  Enables use of the ECC hardware scalar multiply path for ECDSA sign and
	  verify operations when available. If disabled, ECDSA uses software ECC.

config NOXTLS_ESP_HW_MPI
	bool "Use ESP hardware MPI for P-256 bignum (mod, mod_exp)"
	default y
	depends on NOXTLS_FEATURE_PKC
	help
	  Registers NoxTLS bignum hooks that call the ESP-IDF MPI implementation
	  (PKC peripheral via esp_bignum). Speeds ECDSA modular inverse and field
	  reduction. Also enable mbedTLS "Use hardware MPI" in Component config.

config NOXTLS_ESP_HW_AES
	bool "Use ESP hardware AES backend"
	default y
	depends on NOXTLS_FEATURE_AES && SOC_AES_SUPPORTED
	help
	  Enables AES block offload through ESP-IDF HAL (esp_aes_*). Targets
	  without hardware AES support automatically fall back to software.

config NOXTLS_ESP_HW_SHA
	bool "Use ESP hardware SHA backend (SHA-224/256)"
	default y
	depends on (NOXTLS_FEATURE_SHA224 || NOXTLS_FEATURE_SHA256) && SOC_SHA_SUPPORTED
	help
	  Enables SHA-224/SHA-256 block processing through ESP-IDF SHA HAL when
	  available. Targets without SHA hardware support use software fallback.

endmenu

config NOXTLS_SAMPLE_TLS_CONNECT
	bool "TLS client sample: perform network handshake"
	default n
	help
	  When enabled, the tls_client example opens a TCP connection and runs a
	  TLS 1.3 handshake. Leave disabled for init-only smoke testing.

config NOXTLS_SAMPLE_TLS_HOST
	string "TLS client sample hostname"
	default "example.com"
	depends on NOXTLS_SAMPLE_TLS_CONNECT

rsource "Kconfig.noxtls.generated"

endif # NOXTLS
