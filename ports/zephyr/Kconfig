	bool "AES-CCM"
	default y
	depends on NOXTLS_FEATURE_AES

config NOXTLS_FEATURE_AES_CMAC
	bool "AES-CMAC"
	default y
	depends on NOXTLS_FEATURE_AES

config NOXTLS_FEATURE_ARIA
	bool "ARIA"
	default y
	depends on NOXTLS_FEATURE_ENCRYPTION

config NOXTLS_FEATURE_CAMELLIA
	bool "Camellia"
	default y
	depends on NOXTLS_FEATURE_ENCRYPTION

config NOXTLS_FEATURE_CHACHA20_POLY1305
	bool "ChaCha20-Poly1305"
	default y
	depends on NOXTLS_FEATURE_ENCRYPTION

config NOXTLS_FEATURE_DES
	bool "DES"
	default y
	depends on NOXTLS_FEATURE_ENCRYPTION

config NOXTLS_FEATURE_RC4
	bool "RC4"
	default y
	depends on NOXTLS_FEATURE_ENCRYPTION

config NOXTLS_FEATURE_RSA
	bool "RSA"
	default y
	depends on NOXTLS_FEATURE_PKC

