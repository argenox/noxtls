# Zephyr Kconfig for NoxTLS

menuconfig NOXTLS
	bool "NoxTLS cryptography and TLS library"
	help
	  Enable the NoxTLS library from Argenox. Add this module to your west
	  manifest at modules/crypto/noxtls (see ports/zephyr/README.md).

if NOXTLS

choice NOXTLS_PROFILE
	prompt "Feature profile"
	default NOXTLS_PROFILE_DEFAULT
	help
	  Predefined feature sets. Individual feature options below apply when
	  the profile is "default".

config NOXTLS_PROFILE_DEFAULT
	bool "default"

config NOXTLS_PROFILE_MINIMAL_TLS_CLIENT
	bool "minimal_tls_client"

config NOXTLS_PROFILE_TLS_SERVER_PKI
	bool "tls_server_pki"

config NOXTLS_PROFILE_CRYPTO_ONLY
	bool "crypto_only"

config NOXTLS_PROFILE_FIPS_LIKE
	bool "fips_like_profile"

endchoice

config NOXTLS_PROFILE
	string
	default "minimal_tls_client" if NOXTLS_PROFILE_MINIMAL_TLS_CLIENT
	default "tls_server_pki" if NOXTLS_PROFILE_TLS_SERVER_PKI
	default "crypto_only" if NOXTLS_PROFILE_CRYPTO_ONLY
	default "fips_like_profile" if NOXTLS_PROFILE_FIPS_LIKE
	default "default"

choice NOXTLS_SIDECHANNEL
	prompt "Side-channel profile"
	default NOXTLS_SIDECHANNEL_BALANCED

config NOXTLS_SIDECHANNEL_PERFORMANCE
	bool "performance"

config NOXTLS_SIDECHANNEL_BALANCED
	bool "balanced"

config NOXTLS_SIDECHANNEL_CONSTANT_TIME_STRICT
	bool "constant_time_strict"

endchoice

config NOXTLS_SIDECHANNEL
	string
	default "performance" if NOXTLS_SIDECHANNEL_PERFORMANCE
	default "constant_time_strict" if NOXTLS_SIDECHANNEL_CONSTANT_TIME_STRICT
	default "balanced"

config NOXTLS_FEATURE_HASH
	bool "Hash (message digests)"
	default y

config NOXTLS_FEATURE_ENCRYPTION
	bool "Symmetric encryption"
	default y

config NOXTLS_FEATURE_DRBG
	bool "DRBG (random number generator)"
	default y

config NOXTLS_FEATURE_PKC
	bool "Public-key cryptography"
	default y

config NOXTLS_FEATURE_CERT
	bool "X.509 certificates"
	default y
	depends on NOXTLS_FEATURE_PKC

config NOXTLS_FEATURE_TLS
	bool "TLS / DTLS stack"
	default y
	depends on NOXTLS_FEATURE_CERT

config NOXTLS_FEATURE_TLS10
	bool "TLS 1.0"
	default n
	depends on NOXTLS_FEATURE_TLS

config NOXTLS_FEATURE_TLS11
	bool "TLS 1.1"
	default n
	depends on NOXTLS_FEATURE_TLS

config NOXTLS_FEATURE_TLS12
	bool "TLS 1.2"
	default y
	depends on NOXTLS_FEATURE_TLS

config NOXTLS_FEATURE_TLS13
	bool "TLS 1.3"
	default y
	depends on NOXTLS_FEATURE_TLS

config NOXTLS_FEATURE_DTLS
	bool "DTLS"
	default n
	depends on NOXTLS_FEATURE_TLS

config NOXTLS_FEATURE_MD4
	bool "MD4"
	default n
	depends on NOXTLS_FEATURE_HASH

config NOXTLS_FEATURE_MD5
	bool "MD5"
	default y
	depends on NOXTLS_FEATURE_HASH

config NOXTLS_FEATURE_SHA1
	bool "SHA-1"
	default y
	depends on NOXTLS_FEATURE_HASH

config NOXTLS_FEATURE_SHA224
	bool "SHA-224"
	default y
	depends on NOXTLS_FEATURE_HASH

config NOXTLS_FEATURE_SHA256
	bool "SHA-256"
	default y
	depends on NOXTLS_FEATURE_HASH

config NOXTLS_FEATURE_SHA384
	bool "SHA-384"
	default y
	depends on NOXTLS_FEATURE_HASH

config NOXTLS_FEATURE_SHA512
	bool "SHA-512"
	default y
	depends on NOXTLS_FEATURE_HASH

config NOXTLS_FEATURE_SHA3
	bool "SHA-3"
	default y
	depends on NOXTLS_FEATURE_HASH

config NOXTLS_FEATURE_RIPEMD160
	bool "RIPEMD-160"
	default y
	depends on NOXTLS_FEATURE_HASH

config NOXTLS_FEATURE_BLAKE2
	bool "BLAKE2"
	default y
	depends on NOXTLS_FEATURE_HASH

config NOXTLS_FEATURE_AES
	bool "AES"
	default y
	depends on NOXTLS_FEATURE_ENCRYPTION

config NOXTLS_FEATURE_AES_128
	bool "AES-128"
	default y
	depends on NOXTLS_FEATURE_AES

config NOXTLS_FEATURE_AES_192
	bool "AES-192"
	default y
	depends on NOXTLS_FEATURE_AES

config NOXTLS_FEATURE_AES_256
	bool "AES-256"
	default y
	depends on NOXTLS_FEATURE_AES

config NOXTLS_FEATURE_AES_ECB
	bool "AES-ECB"
	default y
	depends on NOXTLS_FEATURE_AES

config NOXTLS_FEATURE_AES_CBC
	bool "AES-CBC"
	default y
	depends on NOXTLS_FEATURE_AES

