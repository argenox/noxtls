set(CMAKE_SYSTEM_NAME Generic)
set(CMAKE_SYSTEM_PROCESSOR riscv32)
set(CMAKE_TRY_COMPILE_TARGET_TYPE STATIC_LIBRARY)
set(CMAKE_TRY_COMPILE_PLATFORM_VARIABLES RISCV_GNU_TOOLCHAIN_ROOT RISCV_GNU_TOOLCHAIN_PREFIX)

set(RISCV_GNU_TOOLCHAIN_ROOT "" CACHE PATH "Root of RISC-V GNU toolchain installation")
set(RISCV_GNU_TOOLCHAIN_PREFIX "riscv-none-elf" CACHE STRING "RISC-V toolchain prefix")
if(NOT RISCV_GNU_TOOLCHAIN_ROOT AND DEFINED ENV{RISCV_GNU_TOOLCHAIN_ROOT})
    set(RISCV_GNU_TOOLCHAIN_ROOT "$ENV{RISCV_GNU_TOOLCHAIN_ROOT}")
endif()

if(RISCV_GNU_TOOLCHAIN_ROOT)
    set(_riscv_bin_dir "${RISCV_GNU_TOOLCHAIN_ROOT}/bin")
    set(_RISCV_GCC "${_riscv_bin_dir}/${RISCV_GNU_TOOLCHAIN_PREFIX}-gcc")
    set(_RISCV_GXX "${_riscv_bin_dir}/${RISCV_GNU_TOOLCHAIN_PREFIX}-g++")
    set(_RISCV_OBJDUMP "${_riscv_bin_dir}/${RISCV_GNU_TOOLCHAIN_PREFIX}-objdump")
    set(_RISCV_SIZE "${_riscv_bin_dir}/${RISCV_GNU_TOOLCHAIN_PREFIX}-size")
    if(WIN32)
        if(NOT EXISTS "${_RISCV_GCC}.exe")
            message(FATAL_ERROR "Could not find ${_RISCV_GCC}.exe")
        endif()
        set(_RISCV_GCC "${_RISCV_GCC}.exe")
        set(_RISCV_GXX "${_RISCV_GXX}.exe")
        set(_RISCV_OBJDUMP "${_RISCV_OBJDUMP}.exe")
        set(_RISCV_SIZE "${_RISCV_SIZE}.exe")
    elseif(NOT EXISTS "${_RISCV_GCC}")
        message(FATAL_ERROR "Could not find ${_RISCV_GCC}")
    endif()
else()
    find_program(_RISCV_GCC "${RISCV_GNU_TOOLCHAIN_PREFIX}-gcc" REQUIRED)
    find_program(_RISCV_GXX "${RISCV_GNU_TOOLCHAIN_PREFIX}-g++")
    find_program(_RISCV_OBJDUMP "${RISCV_GNU_TOOLCHAIN_PREFIX}-objdump" REQUIRED)
    find_program(_RISCV_SIZE "${RISCV_GNU_TOOLCHAIN_PREFIX}-size" REQUIRED)
endif()

set(CMAKE_C_COMPILER "${_RISCV_GCC}" CACHE FILEPATH "" FORCE)
set(CMAKE_ASM_COMPILER "${_RISCV_GCC}" CACHE FILEPATH "" FORCE)
if(_RISCV_GXX)
    set(CMAKE_CXX_COMPILER "${_RISCV_GXX}" CACHE FILEPATH "" FORCE)
endif()
set(CMAKE_OBJDUMP "${_RISCV_OBJDUMP}" CACHE FILEPATH "" FORCE)
set(CMAKE_SIZE "${_RISCV_SIZE}" CACHE FILEPATH "" FORCE)
