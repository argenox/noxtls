# Doxyfile for NoxTLS - XML output only (for Docusaurus API docs)
# Run from repository root: doxygen Doxyfile

PROJECT_NAME          = "NoxTLS"
PROJECT_NUMBER        = 0.1.21
OUTPUT_DIRECTORY       = build/doxygen
CREATE_SUBDIRS        = NO

# Input: library, utility, and applications
INPUT                 = . \
                        noxtls-lib \
                        utility \
                        applications
FILE_PATTERNS         = *.c *.h
RECURSIVE             = YES
EXCLUDE               = ut
EXCLUDE_PATTERNS      = *_ut.c \
                        *_ut.h \
                        */.git/*
# Exclude internal/implementation symbols from public API docs
EXCLUDE_SYMBOLS       = camellia_key_schedule \
                        camellia_encrypt_block_internal \
                        camellia_decrypt_block_internal

# Include paths so Doxygen can resolve #includes (match CMakeLists.txt)
INCLUDE_PATH          = . \
                        utility \
                        applications/noxtls \
                        noxtls-lib \
                        noxtls-lib/common \
                        noxtls-lib/mdigest \
                        noxtls-lib/mdigest/md4 \
                        noxtls-lib/mdigest/md5 \
                        noxtls-lib/mdigest/sha1 \
                        noxtls-lib/mdigest/sha256 \
                        noxtls-lib/mdigest/sha512 \
                        noxtls-lib/mdigest/sha3 \
                        noxtls-lib/mdigest/blake2 \
                        noxtls-lib/mdigest/ripemd160 \
                        noxtls-lib/encryption \
                        noxtls-lib/encryption/aria \
                        noxtls-lib/encryption/aes \
                        noxtls-lib/encryption/camellia \
                        noxtls-lib/encryption/chacha20 \
                        noxtls-lib/certs \
                        noxtls-lib/pkc \
                        noxtls-lib/pkc/rsa \
                        noxtls-lib/pkc/ecc \
                        noxtls-lib/pkc/ecdsa \
                        noxtls-lib/pkc/ecdh \
                        noxtls-lib/drbg \
                        noxtls-lib/tls

# XML only - no HTML (API docs generated by scripts from XML)
GENERATE_HTML         = NO
GENERATE_XML          = YES
XML_OUTPUT            = xml
GENERATE_LATEX        = NO

# C project
OPTIMIZE_OUTPUT_FOR_C = YES
ENABLE_PREPROCESSING  = YES
MACRO_EXPANSION       = YES
EXPAND_AS_DEFINED     =

# Extract all relevant items
EXTRACT_ALL           = YES
EXTRACT_STATIC        = YES
EXTRACT_LOCAL_CLASSES = YES
EXTRACT_LOCAL_METHODS = NO
HIDE_UNDOC_MEMBERS    = NO
HIDE_UNDOC_CLASSES    = NO
BRIEF_MEMBER_DESC     = YES
REPEAT_BRIEF          = YES

# Grouping (matches @defgroup / @addtogroup in source)
GROUP_GRAPHS          = NO

# No diagrams by default (set to YES and install Graphviz if needed)
HAVE_DOT              = NO

# Quiet
QUIET                 = YES
WARNINGS              = YES
WARN_IF_UNDOCUMENTED  = NO
